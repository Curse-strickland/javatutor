{
  "name": "JavaTutor",
  "image": "mcr.microsoft.com/devcontainers/base:jammy",

  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "installMaven": "true",
      "installGradle": "false"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },

  "forwardPorts": [8080, 5173],

  "portsAttributes": {
    "8080": {
      "label": "Backend (Spring Boot)",
      "onAutoForward": "silent"
    },
    "5173": {
      "label": "Frontend (Vite)",
      "onAutoForward": "notify"
    }
  },

  "postCreateCommand": "chmod +x backend/mvnw && cd frontend && npm install",

  "postStartCommand": "cd backend && nohup ./mvnw spring-boot:run -DskipTests > /tmp/backend.log 2>&1 & disown ; cd frontend && nohup npm run dev > /tmp/frontend.log 2>&1 & disown ; echo 'Services starting...'",

  "customizations": {
    "vscode": {
      "extensions": [
        "vue.volar",
        "bradlc.vscode-tailwindcss",
        "vscjava.vscode-java-pack"
      ]
    }
  }
}
